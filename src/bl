epilog = r'''
bl new jazz
bl new jazz --blog_dir ~/blog
bl -n new jazz
'''[1:]

import argparse
import logging
from pathlib import Path


class MyFormatter(logging.Formatter):
    def format(self, record: logging.LogRecord) -> str:
        color = {
            logging.CRITICAL: '\x1b[31m',
            logging.ERROR: '\x1b[31m',
            logging.WARNING: '\x1b[33m',
            logging.INFO: '\x1b[34m',
            logging.DEBUG: '\x1b[37m',
        }[record.levelno]
        fn = '' if record.funcName == '<module>' else f' {record.funcName}()'
        fmt = f'{color}[%(levelname)1.1s %(asctime)s %(filename)s:%(lineno)d{fn}] %(message)s\x1b[m'
        return logging.Formatter(fmt=fmt, datefmt='%T').format(record)


logger = logging.getLogger(__name__)
logger.setLevel(logging.DEBUG)
logger_handler = logging.StreamHandler()
logger_handler.setFormatter(MyFormatter())
logger.addHandler(logger_handler)


class ArgumentDefaultsRawTextHelpFormatter(argparse.ArgumentDefaultsHelpFormatter, argparse.RawTextHelpFormatter):
    pass


PAGE_TSX_TEMPLATE = '''\
// "use client";
// http://localhost:3000/{name}

// [](file://{mdx_path})
import Mdx from './page_.mdx'

export default function Page() {{
  return <Mdx />;
}}
'''

PAGE_MDX_TEMPLATE = '''\
{{/* http://localhost:3000/{name} */}}
{{/* [](file://{tsx_path}) */}}
`{mdx_path}`
'''


def main() -> int:
    parser = argparse.ArgumentParser(formatter_class=ArgumentDefaultsRawTextHelpFormatter, epilog=epilog)
    parser.add_argument('-n', '--dry_run', action='store_true')
    parser.add_argument('--blog_dir', type=Path, default=Path.home() / 'blog')
    subparsers = parser.add_subparsers(dest='subcommand_name', required=True)

    subparser = subparsers.add_parser('new', formatter_class=ArgumentDefaultsRawTextHelpFormatter,
                                      help='create <blog_dir>/app/<name>/page.tsx and page_.mdx')
    subparser.set_defaults(func=cmd_new)
    subparser.add_argument('name', help='page name, e.g. "jazz"')

    args = parser.parse_args()
    logger.debug(f'{args=}')
    return args.func(args)


def cmd_new(args: argparse.Namespace) -> int:
    name: str = args.name
    blog_dir: Path = args.blog_dir.expanduser().resolve()
    page_dir = blog_dir / 'app' / name
    tsx_path = page_dir / 'page.tsx'
    mdx_path = page_dir / 'page_.mdx'

    tsx_content = PAGE_TSX_TEMPLATE.format(name=name, mdx_path=mdx_path)
    mdx_content = PAGE_MDX_TEMPLATE.format(name=name, tsx_path=tsx_path, mdx_path=mdx_path)

    if args.dry_run:
        print(f'mkdir -p {page_dir}')
        print(f"cat > {tsx_path} <<'EOF'\n{tsx_content}EOF")
        print(f"cat > {mdx_path} <<'EOF'\n{mdx_content}EOF")
        return 0

    if tsx_path.exists() or mdx_path.exists():
        logger.error(f'refusing to overwrite existing files in {page_dir}')
        return 1

    logger.info(f'mkdir -p {page_dir}')
    page_dir.mkdir(parents=True, exist_ok=True)
    logger.info(f'write {tsx_path}')
    tsx_path.write_text(tsx_content)
    logger.info(f'write {mdx_path}')
    mdx_path.write_text(mdx_content)
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
